# Database
DATABASE_URL="postgresql://user:password@localhost:5432/snapnext?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-nextauth-secret-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Supabase (Optional - if using Supabase)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Cloud Storage (S3/Cloudinary)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="ap-southeast-1"
AWS_BUCKET_NAME="snapnext-photos"

# Payment Gateways
TOKOPAY_MERCHANT_ID="your-tokopay-merchant-id"
TOKOPAY_API_KEY="your-tokopay-api-key"
TOKOPAY_SECRET_KEY="your-tokopay-secret-key"

MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
MIDTRANS_IS_PRODUCTION="false"

DOKU_MERCHANT_ID="your-doku-merchant-id"
DOKU_SECRET_KEY="your-doku-secret-key"

# QRIS
QRIS_MERCHANT_ID="your-qris-merchant-id"
QRIS_API_KEY="your-qris-api-key"

# WhatsApp (Fonnte, Wablas, or Wanotif)
FONNTE_API_TOKEN="your-fonnte-token"  # Get from https://fonnte.com
WABLAS_API_TOKEN="your-wablas-token"   # Get from https://wablas.com
WANOTIF_API_TOKEN="your-wanotif-token"  # Get from https://wanotif.com
WHATSAPP_SENDER_NUMBER="your-sender-number"

# App Config
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Thermal Printer (ESC/POS)
PRINTER_HOST="192.168.1.100"
PRINTER_PORT=9100

# Demo Mode (for local testing)
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_DEMO_PAYMENT_DELAY=3000  # 3 seconds auto-success
NEXT_PUBLIC_DEMO_PRINT_NOTIFICATION=true  # Show notification instead of actual print