# ============================================================
# SnapNext SaaS - Environment Variables
# PRODUCTION (Supabase PostgreSQL)
# ============================================================
# Copy file ini ke .env.local untuk development
# atau set di Vercel Dashboard → Settings → Environment Variables
# ============================================================

# ============================================================
# DATABASE (Supabase)
# ============================================================
# Ambil dari: Supabase Dashboard → Settings → Database → Connection string

# Untuk Prisma runtime (connection pooling via pgBouncer - port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Untuk Prisma migrate (direct connection - port 5432)
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ============================================================
# AUTH / JWT
# ============================================================
JWT_SECRET="ganti-dengan-random-string-minimal-32-karakter"
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# ============================================================
# APP CONFIG
# ============================================================
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://photobox-saas-main-ews1.vercel.app"
NEXT_PUBLIC_DEMO_MODE="false"

# ============================================================
# PAYMENT PROVIDERS
# ============================================================

# --- DOKU (Recommended untuk QRIS Indonesia) ---
DOKU_MERCHANT_ID="your-doku-merchant-id"
DOKU_SECRET_KEY="your-doku-secret-key"
DOKU_IS_PRODUCTION="true"

# --- MIDTRANS ---
MIDTRANS_SERVER_KEY="your-midtrans-server-key"
MIDTRANS_CLIENT_KEY="your-midtrans-client-key"
MIDTRANS_IS_PRODUCTION="true"

# --- TOKOPAY ---
TOKOPAY_MERCHANT_ID="your-tokopay-merchant-id"
TOKOPAY_API_KEY="your-tokopay-api-key"
TOKOPAY_SECRET_KEY="your-tokopay-secret-key"
TOKOPAY_IS_PRODUCTION="true"

# ============================================================
# STORAGE (untuk foto hasil sesi)
# ============================================================
# Supabase Storage (sudah include, gratis 1GB)
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"  # Jangan expose ke client!
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
